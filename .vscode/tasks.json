{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compile and Run CP",
            "command": "g++",
            "args": [
                "-std=c++17",
                "${file}",
                "-o",
                "${workspaceFolder}/a.out",
                "&&",
                "${workspaceFolder}/a.out",
                "<",
                "${workspaceFolder}/input.txt",
                ">",
                "${workspaceFolder}/output.txt"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "never",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}